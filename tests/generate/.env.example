OSU_API_KEY=YOUR_OSU_API_KEY

# Either provide a token directly...
OSU_ACCESS_TOKEN=
# ...or provide OAuth app credentials to generate one interactively in the browser.
# The app's callback URL must match OSU_REDIRECT_URI (default http://localhost:7270/callback).
OSU_CLIENT_ID=YOUR_CLIENT_ID
OSU_CLIENT_SECRET=YOUR_CLIENT_SECRET
OSU_REDIRECT_URI=http://localhost:7270/callback

# Optional: credentials for an OAuth app on https://dev.ppy.sh to generate
# data for state-mutating endpoints (forums, chat). Skipped if unset.
OSU_DEV_ACCESS_TOKEN=
OSU_DEV_CLIENT_ID=
OSU_DEV_CLIENT_SECRET=
OSU_DEV_REDIRECT_URI=http://localhost:7270/callback
